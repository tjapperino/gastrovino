{
  "name": "gastrovino",
  "version": "1.0.0",
  "description": "Gastrovino Rotterdam - data ingestie & scraping",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "scrape": "node src/scripts/scraper.js",
    "scrape:debug": "DEBUG=pw:api node src/scripts/scraper.js",
    "seed": "node src/scripts/seed-data.js",
    "seed:dry": "node src/scripts/seed-data.js --dry-run",
    "seed:mem": "node src/scripts/seed-data.js --mem",
    "db:up": "docker-compose up -d",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "lucide-react": "^1.17.0",
    "next": "^15.5.19",
    "pg": "^8.21.0",
    "pg-mem": "^3.0.14",
    "playwright": "^1.44.0",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "fsevents@2.3.2": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  }
}
